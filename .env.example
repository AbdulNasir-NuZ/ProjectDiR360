# Point the frontend at the ReDi NestJS backend.
# In dev: http://localhost:4000 (the backend's default port).
# In prod: set to your deployed backend origin.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Public origin of THIS frontend (used to build /verify/<tokenId> URLs that ship
# in the QR code on the certificate). Optional in dev — falls back to
# window.location.origin when running in the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000
